```ejs
<%- include("partials/header.ejs") %>

<!-- Content -->
<main class="py-5">
  <div class="container">
    <div class="row">
      <div class="col-md-12">

        <div class="card">

          <div class="card-header card-title">
            <div class="d-flex align-items-center">
              <h2 class="mb-0">All Contacts</h2>

              <div class="ml-auto">
                <a href="/add-contacts" class="btn btn-success">
                  <i class="fa fa-plus-circle"></i> Add New
                </a>
              </div>
            </div>
          </div>

          <div class="card-body">

            <table class="table table-striped table-hover">

              <thead>
                <tr>
                  <th>#</th>
                  <th>First Name</th>
                  <th>Last Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th width="150">Actions</th>
                </tr>
              </thead>

              <tbody>

                <% if (contacts.length > 0) { %>

                  <% contacts.forEach((contact, index) => { %>

                    <tr>
                      <td><%= index + 1 %></td>
                      <td><%= contact.firstName %></td>
                      <td><%= contact.lastName %></td>
                      <td><%= contact.email %></td>
                      <td><%= contact.phone %></td>

                      <td>

                        <a
                          href="/show-contacts/<%= contact._id %>"
                          class="btn btn-sm btn-circle btn-outline-info"
                          title="Show"
                        >
                          <i class="fa fa-eye"></i>
                        </a>

                        <a
                          href="/update-contacts/<%= contact._id %>"
                          class="btn btn-sm btn-circle btn-outline-secondary"
                          title="Edit"
                        >
                          <i class="fa fa-edit"></i>
                        </a>

                        <a
                          href="/delete-contact/<%= contact._id %>"
                          class="btn btn-sm btn-circle btn-outline-danger"
                          title="Delete"
                          onclick="return confirm('Are you sure?')"
                        >
                          <i class="fa fa-times"></i>
                        </a>

                      </td>
                    </tr>

                  <% }) %>

                <% } else { %>

                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                      No Contacts Found
                    </td>
                  </tr>

                <% } %>

              </tbody>

            </table>

          </div>

        </div>

      </div>
    </div>
  </div>
</main>

<%- include("partials/footer.ejs") %>
```
